{
  "game_name": "Metal Gear Solid V: The Phantom Pain",
  "game_id": "metal_gear_5_the_phantom_pain",
  "description": "Default PC keyboard and mouse bindings for MGSV:TPP. Edit keys here if you have remapped controls in-game.",
  "game_context": "Metal Gear Solid V: The Phantom Pain is a stealth action game. You play as Snake infiltrating enemy outposts. Priorities: stay hidden, take down guards silently, rescue prisoners, explore objectives. When enemies are spotted on-screen aim and shoot. Sprint between cover points. Scan surroundings with LOOK actions before moving into open ground. Avoid repeating the same action — vary movement, looking, and combat.",

  "action_list": [
    "MOVE_FORWARD",
    "MOVE_BACKWARD",
    "MOVE_LEFT",
    "MOVE_RIGHT",
    "SPRINT_FORWARD",
    "LOOK_LEFT",
    "LOOK_RIGHT",
    "LOOK_UP",
    "LOOK_DOWN",
    "TAKE_COVER",
    "CONTEXT_ACTION",
    "AIM",
    "AIM_SHOOT",
    "RELOAD",
    "QUICK_DIVE",
    "IDLE"
  ],

  "key_map": {
    "MOVE_FORWARD": { "type": "keyboard", "key": "w", "hold_ms": 300 },
    "MOVE_BACKWARD": { "type": "keyboard", "key": "s", "hold_ms": 200 },
    "MOVE_LEFT": { "type": "keyboard", "key": "a", "hold_ms": 200 },
    "MOVE_RIGHT": { "type": "keyboard", "key": "d", "hold_ms": 200 },
    "SPRINT_FORWARD": {
      "type": "combo",
      "keys": ["shift", "w"],
      "hold_ms": 600
    },
    "LOOK_LEFT": { "type": "mouse_move", "dx": -450, "dy": 0, "steps": 10 },
    "LOOK_RIGHT": { "type": "mouse_move", "dx": 450, "dy": 0, "steps": 10 },
    "LOOK_UP": { "type": "mouse_move", "dx": 0, "dy": -220, "steps": 6 },
    "LOOK_DOWN": { "type": "mouse_move", "dx": 0, "dy": 220, "steps": 6 },
    "TAKE_COVER": { "type": "keyboard", "key": "c", "hold_ms": 100 },
    "CONTEXT_ACTION": { "type": "keyboard", "key": "e", "hold_ms": 100 },
    "AIM": {
      "type": "sequence",
      "steps": [{ "type": "mouse", "button": "right", "hold_ms": 1200 }]
    },
    "AIM_SHOOT": {
      "type": "sequence",
      "steps": [
        {
          "type": "mouse",
          "button": "right",
          "hold_ms": 350,
          "delay_after_ms": 80
        },
        { "type": "mouse", "button": "left", "hold_ms": 100 }
      ]
    },
    "RELOAD": { "type": "keyboard", "key": "r", "hold_ms": 100 },
    "QUICK_DIVE": { "type": "keyboard", "key": "space", "hold_ms": 100 },
    "IDLE": null,

    "SPRINT_TOGGLE": { "type": "keyboard", "key": "shift" },
    "WALK_TOGGLE": { "type": "keyboard", "key": "ctrl" },
    "CHANGE_STANCE": { "type": "keyboard", "key": "c" },
    "ZOOM_SWITCH": { "type": "keyboard", "key": "v" },
    "BINOCULARS": { "type": "keyboard", "key": "f" },
    "RADIO": { "type": "keyboard", "key": "q" },
    "LIGHTS_TOGGLE": { "type": "keyboard", "key": "x" },
    "PAUSE": { "type": "keyboard", "key": "esc" },
    "IDROID": { "type": "keyboard", "key": "tab" },
    "PLACE_MARKER": { "type": "mouse", "button": "middle" },
    "SUPPRESSOR_TOGGLE": { "type": "keyboard", "key": "g" },
    "ATTACK": { "type": "mouse", "button": "left" },
    "QUICK_PRIMARY": { "type": "keyboard", "key": "1" },
