# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit your real credentials.
#
# ┌─────────────────────────────────────────────────────────────────────────┐
# │  LLM PROVIDER — at least ONE provider must be configured               │
# │  Supported: azure | openai | gemini | anthropic                        │
# │  Leave LLM_PROVIDER unset for auto-detection (first found wins).       │
# └─────────────────────────────────────────────────────────────────────────┘

# Optional: force a specific provider (comment out for auto-detect)
# LLM_PROVIDER=azure

# ── Azure OpenAI ────────────────────────────────────────────────────────────
# Required when using: LLM_PROVIDER=azure  (or auto-detected if set)
AZURE_OPENAI_ENDPOINT=https://<your-resource-name>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-azure-api-key>
AZURE_OPENAI_API_VERSION=2025-01-01-preview
AZURE_DEPLOYMENT_NAME=gpt-5-nano

# ── OpenAI ──────────────────────────────────────────────────────────────────
# Required when using: LLM_PROVIDER=openai  (or auto-detected if set)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# ── Google Gemini ───────────────────────────────────────────────────────────
# Required when using: LLM_PROVIDER=gemini  (or auto-detected if set)
# Get your key at https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=<your-gemini-api-key>
# GEMINI_MODEL=gemini-2.0-flash

# ── Anthropic Claude ────────────────────────────────────────────────────────
# Required when using: LLM_PROVIDER=anthropic  (or auto-detected if set)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ── Capture region (game window position on screen) ─────────────────────────
# CAPTURE_BACKEND: dxcam = fastest, works with local DirectX full-screen games
#                  mss   = GDI-based, works with Parsec / remote desktop / OBS
# If every action comes back as IDLE, switch to mss.
CAPTURE_BACKEND=dxcam
# Leave at 0,0,1920,1080 for full-screen, or set to your game window bounds.
CAPTURE_X=0
CAPTURE_Y=0
CAPTURE_W=1920
CAPTURE_H=1080

# Size (px) the screenshot is resized to before being sent to the LLM.
# 512 matches GPT "low detail" tile size — fastest + cheapest.
CAPTURE_RESIZE=512

# JPEG compression quality (1-100). 80 gives small file with good visual quality.
JPEG_QUALITY=80

# ── LLM settings ────────────────────────────────────────────────────────────
# For reasoning/thinking models (GPT-5 Nano, o1, o3-mini, Gemini 2.0 Flash
# Thinking): set MAX_TOKENS to 2000+ — they use tokens internally to think
# before writing the visible answer. Too low = empty response = always IDLE.
# For standard models (GPT-4o, Claude Sonnet, Gemini Flash): 10-20 is fine.
MAX_TOKENS=10000
LLM_TEMPERATURE=0.0

# ── Input ────────────────────────────────────────────────────────────────────
# How long (ms) to hold a key down before releasing
KEY_HOLD_MS=50

# ── Bot loop ─────────────────────────────────────────────────────────────────
# 0 = run forever; any positive number = stop after N frames
MAX_FRAMES=0

# ── Debug ────────────────────────────────────────────────────────────────────
DEBUG_SHOW_FRAME=false
# Set to true to save every frame as debug_frame.jpg to verify what the bot sees
DEBUG_SAVE_FRAME=false
DEBUG_TIMING=false
